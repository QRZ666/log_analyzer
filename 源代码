RULES = {
    "SQL Injection": {
        "union": 2,
        "select": 1,
        "or 1=1": 5,
        "and 1=1": 5,
        "or '1'='1": 5,
        "and '1'='1": 5,
        "1=1": 3,
        "sleep(": 5,
        "benchmark(": 5,
        "information_schema": 4,
        "--": 2,
        "#": 2,
        "/*": 2,
        "id=": 1,
    },
    "XSS": {
        "<script>": 5,
        "<script": 4,
        "alert(": 3,
        "onerror=": 5,
        "onload=": 5,
        "javascript:": 4,
        "onclick=": 4,
        "<img": 3,
        "<svg": 3,
        "prompt(": 3,
        "confirm(": 3,
    },
    "Scanner": {
        "sqlmap": 10,
        "nikto": 10,
        "nmap": 8,
        "acunetix": 10,
        "dirb": 8,
        "gobuster": 8,
    },
    "Path Traversal": {
        "../": 5,
        "..\\": 5,
        "/etc/passwd": 10,
        "windows\\system32": 10,
        "boot.ini": 8,
    },
}

RISK_THRESHOLD = 5


def build_compiled_rules():
    compiled = {}
    for attack_type, rule_dict in RULES.items():
        sorted_keywords = sorted(rule_dict.keys(), key=len, reverse=True)
        pattern = "|".join(re.escape(keyword) for keyword in sorted_keywords)
        compiled[attack_type] = re.compile(pattern, re.IGNORECASE)
    return compiled


COMPILED_RULES = build_compiled_rules()


def extract_ip(line: str) -> str:
    m = re.match(r"^(\S+)", line.strip())
    return m.group(1) if m else "Unknown"


def normalize_line(line: str) -> str:
    try:
        decoded = urllib.parse.unquote(line)
        decoded = urllib.parse.unquote(decoded)
    except Exception:
        decoded = line
    return decoded.lower()


def advanced_sql_patterns():
    return [
        (re.compile(r"'\s+or\s+'\w+'\s*=\s*'\w+'", re.IGNORECASE), 4),
        (re.compile(r"'\s+and\s+'\w+'\s*=\s*'\w+'", re.IGNORECASE), 4),
        (re.compile(r"id\s*=\s*\d+'\s+(or|and)", re.IGNORECASE), 3),
        (re.compile(r"\d+\s+(or|and)\s+\d+\s*=\s*\d+", re.IGNORECASE), 3),
        (re.compile(r"union\s+select", re.IGNORECASE), 4),
    ]


ADV_SQL_PATTERNS = advanced_sql_patterns()


@dataclass
class Finding:
    line_no: int
    ip: str
    score: int
    categories: str
    matched: str
    normalized: str
    raw: str


def analyze_line(line: str, line_no: int) -> tuple[int, set[str], list[str]]:
    normalized = normalize_line(line)
    total_score = 0
    categories = set()
    matches = []

    for attack_type, regex in COMPILED_RULES.items():
        found = regex.findall(normalized)
        if not found:
            continue

        for match in found:
            key = match.lower()
            score = RULES[attack_type].get(key, 0)
            if score == 0 and key in RULES[attack_type]:
                score = RULES[attack_type][key]
            total_score += score
            categories.add(attack_type)
            matches.append(f"{match}({score})")

    if "SQL Injection" in categories or total_score < RISK_THRESHOLD:
        for pattern, score in ADV_SQL_PATTERNS:
            if pattern.search(normalized):
                total_score += score
                categories.add("SQL Injection")
                matches.append(f"advanced_sql_pattern({score})")

    return total_score, categories, matches[:10]


class LogAnalysisWorker(QThread):
    progress = pyqtSignal(int)
    status = pyqtSignal(str)
    finished_analysis = pyqtSignal(list, dict)

    def __init__(self, file_path: str, parent=None):
        super().__init__(parent)
        self.file_path = file_path

    def run(self):
        findings = []
        ip_attack_count = defaultdict(int)

        try:
            with open(self.file_path, "r", encoding="utf-8", errors="ignore") as f:
                lines = f.readlines()

            total_lines = max(len(lines), 1)
            self.status.emit("开始分析...")

            for idx, line in enumerate(lines, start=1):
                score, categories, matches = analyze_line(line, idx)
                if score >= RISK_THRESHOLD:
                    ip = extract_ip(line)
                    ip_attack_count[ip] += 1
                    findings.append(
                        Finding(
                            line_no=idx,
                            ip=ip,
                            score=score,
                            categories=", ".join(sorted(categories)) if categories else "Unknown",
                            matched=", ".join(matches),
                            normalized=normalize_line(line)[:250],
                            raw=line.strip()[:250],
                        )
                    )

                if idx % 50 == 0 or idx == total_lines:
                    self.progress.emit(int(idx * 100 / total_lines))
                    self.status.emit(f"分析中... {idx}/{total_lines}")

            self.progress.emit(100)
            self.status.emit("分析完成")
            self.finished_analysis.emit(findings, dict(ip_attack_count))
        except Exception as e:
            self.status.emit(f"分析失败：{e}")
            self.finished_analysis.emit([], {})


class DropArea(QLabel):
    file_dropped = pyqtSignal(str)

    def __init__(self):
        super().__init__()
        self.setAcceptDrops(True)
        self.setAlignment(Qt.AlignCenter)
        self.setText("把日志文件拖到这里\n或者点击“选择文件”")
        self.setMinimumHeight(120)
        self.setObjectName("DropArea")

    def dragEnterEvent(self, event: QDragEnterEvent):
        if event.mimeData().hasUrls():
            event.acceptProposedAction()

    def dropEvent(self, event: QDropEvent):
        urls = event.mimeData().urls()
        if not urls:
            return
        path = urls[0].toLocalFile()
        if path:
            self.file_dropped.emit(path)


