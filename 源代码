    def choose_file(self):
        path, _ = QFileDialog.getOpenFileName(
            self,
            "选择日志文件",
            "",
            "Log Files (*.log *.txt *.csv);;All Files (*)"
        )
        if path:
            self.load_file(path)

    def load_file(self, path: str):
        self.file_path = path
        self.file_edit.setText(path)
        self.drop_area.setText(f"已选择文件：\n{path}\n\n点击“开始分析”")
        self.status_label.setText("文件已加载")
        self.detail.setPlainText("")
        self.clear_results()
        self.progress_bar.setValue(0)

    def clear_results(self):
        self.table.setRowCount(0)
        self.ip_table.setRowCount(0)
        self.findings = []
        self.ip_stats = {}

    def start_analysis(self):
        if not self.file_path:
            QMessageBox.warning(self, "提示", "请先选择或拖入日志文件。")
            return

        self.clear_results()
        self.status_label.setText("准备分析...")
        self.progress_bar.setValue(0)

        self.worker = LogAnalysisWorker(self.file_path)
        self.worker.progress.connect(self.progress_bar.setValue)
        self.worker.status.connect(self.status_label.setText)
        self.worker.finished_analysis.connect(self.on_analysis_finished)
        self.worker.start()

    def on_analysis_finished(self, findings, ip_stats):
        self.findings = findings
        self.ip_stats = ip_stats
        self.populate_table()
        self.populate_ip_table()

        if not findings:
            self.detail.setPlainText("未发现达到阈值的攻击行为。")
        else:
            self.detail.setPlainText(
                f"分析完成。\n"
                f"命中记录：{len(findings)}\n"
                f"攻击IP：{len(ip_stats)}\n"
                f"日志文件：{self.file_path}"
            )

    def populate_table(self):
        self.table.setRowCount(len(self.findings))
        for row, item in enumerate(self.findings):
            values = [
                str(item.line_no),
                item.ip,
                str(item.score),
                item.categories,
                item.matched,
            ]
            for col, value in enumerate(values):
                cell = QTableWidgetItem(value)
                if col in (0, 2):
                    cell.setTextAlignment(Qt.AlignCenter)
                self.table.setItem(row, col, cell)
        self.table.resizeColumnsToContents()

    def populate_ip_table(self):
        sorted_ips = sorted(self.ip_stats.items(), key=lambda x: x[1], reverse=True)
        self.ip_table.setRowCount(len(sorted_ips))
        for row, (ip, count) in enumerate(sorted_ips):
            self.ip_table.setItem(row, 0, QTableWidgetItem(ip))
            count_item = QTableWidgetItem(str(count))
            count_item.setTextAlignment(Qt.AlignCenter)
            self.ip_table.setItem(row, 1, count_item)
        self.ip_table.resizeColumnsToContents()

    def show_selected_detail(self):
        rows = self.table.selectionModel().selectedRows()
        if not rows:
            return
        row = rows[0].row()
        item = self.findings[row]
        detail_text = (
            f"行号：{item.line_no}\n"
            f"IP：{item.ip}\n"
            f"风险分：{item.score}\n"
            f"攻击类型：{item.categories}\n"
            f"命中特征：{item.matched}\n"
            f"\n解码后内容：\n{item.normalized}\n"
            f"\n原始日志：\n{item.raw}"
        )
        self.detail.setPlainText(detail_text)

    def export_report(self):
        if not self.findings:
            QMessageBox.information(self, "提示", "没有可导出的分析结果。")
            return

        save_path, _ = QFileDialog.getSaveFileName(
            self,
            "导出报告",
            "log_report.csv",
            "CSV Files (*.csv);;Text Files (*.txt)"
        )
        if not save_path:
            return

        try:
            if save_path.lower().endswith(".csv"):
                with open(save_path, "w", newline="", encoding="utf-8-sig") as f:
                    writer = csv.writer(f)
                    writer.writerow(["行号", "IP", "风险分", "攻击类型", "命中特征", "解码后内容", "原始日志"])
                    for item in self.findings:
                        writer.writerow([
                            item.line_no,
                            item.ip,
                            item.score,
                            item.categories,
                            item.matched,
                            item.normalized,
                            item.raw,
                        ])
            else:
                with open(save_path, "w", encoding="utf-8") as f:
                    f.write("Web攻击日志分析报告\n")
                    f.write("=" * 60 + "\n\n")
                    f.write(f"文件：{self.file_path}\n")
                    f.write(f"命中记录：{len(self.findings)}\n")
                    f.write(f"攻击IP数：{len(self.ip_stats)}\n\n")
                    for item in self.findings:
                        f.write(f"[行号 {item.line_no}] IP={item.ip} 分数={item.score} 类型={item.categories}\n")
                        f.write(f"命中特征：{item.matched}\n")
                        f.write(f"解码后内容：{item.normalized}\n")
                        f.write(f"原始日志：{item.raw}\n")
                        f.write("-" * 60 + "\n")

            QMessageBox.information(self, "成功", f"报告已导出：\n{save_path}")
        except Exception as e:
            QMessageBox.critical(self, "错误", f"导出失败：{e}")


def main():
    app = QApplication(sys.argv)
    win = LogAnalyzerWindow()
    win.show()
    sys.exit(app.exec_())


if __name__ == "__main__":
    main()
